{
  "cwd": ".",
  "specPath": "spec/SPEC.md",
  "cycleDelayMs": 0,
  "maxCycles": 0,
  "overseerEveryNCycles": 5,
  "overseerOnReviewFailStreak": 2,
  "agentBranch": "curious",
  "ensureAgentBranch": true,
  "llm": {
    "provider": "openai_compat",
    "model": "qwen3-coder:30b",
    "baseUrl": "http://127.0.0.1:11434/v1",
    "apiKey": "local",
    "maxTokens": 16384,
    "temperature": 0.2,
    "timeoutSec": 600,
    "device": "auto",
    "loadIn4bit": false,
    "trustRemoteCode": true,
    "smolagentsAgentType": "tool-calling",
    "fallbackToTransformers": true,
    "fallbackModel": "Qwen/Qwen3-Coder-30B-A3B-Instruct",
    "adapterPath": null
  },
  "_comment_llm_fallback": "When baseUrl (Ollama/vLLM) is unreachable, load fallbackModel via transformers — requires: pip install curious-py[transformers]",
  "reviewLlm": null,
  "overseerLlm": null,
  "verifier": {
    "enabled": false,
    "baseModel": "Qwen/Qwen3-1.7B",
    "modelPath": null,
    "passThreshold": 0.7
  },
  "_comment_llm_providers": {
    "openai_compat": "Ollama / vLLM — model is server tag, e.g. qwen3-coder:30b",
    "transformers": "pip install curious-py[transformers] — model is HF repo id",
    "smolagents": "pip install curious-py[smolagents] — model is HF repo id",
    "litellm": "pip install curious-py[litellm] — model e.g. openai/gpt-5.5"
  },
  "_comment_llm_smolagents_example": {
    "provider": "smolagents",
    "model": "Qwen/Qwen3-Coder-30B-A3B-Instruct",
    "device": "auto",
    "smolagentsAgentType": "tool-calling"
  },
  "harness": {
    "maxTurns": 80,
    "commandTimeoutSec": 300,
    "bestOfN": {
      "enabled": false,
      "n": 4,
      "temperatures": [
        0.2,
        0.5,
        0.7,
        0.9
      ]
    }
  },
  "harvest": {
    "enabled": false,
    "output": ".curious/harvest/"
  },
  "vast": {
    "enabled": false,
    "apiKey": null,
    "interruptible": true,
    "maxDph": 1.25,
    "image": "pytorch/pytorch:2.4.0-cuda12.4-cudnn9-runtime",
    "autoDestroy": true,
    "profiles": {
      "verifier": { "minGpuRamGb": 12, "maxDph": 0.45, "diskGb": 50 },
      "dpo": { "minGpuRamGb": 40, "maxDph": 1.25, "diskGb": 120 },
      "grpo": { "minGpuRamGb": 48, "maxDph": 1.75, "diskGb": 150 }
    }
  },
  "_comment_vast": "Set VAST_API_KEY env (https://cloud.vast.ai/manage-keys/). Training auto-runs on cheapest matching offer unless --local.",
  "train": {
    "outputDir": ".curious/train/dpo",
    "loraR": 16,
    "loraAlpha": 32,
    "learningRate": 5e-6,
    "numTrainEpochs": 1
  }
}